# NormClaim — copy to .env in this directory (repo root) and fill values.
# FastAPI loads .env from the project root (parent of backend/).

# Google AI (required for extraction)
GEMINI_API_KEY=

# Java FHIR microservice (docker-compose sets FHIR_SERVICE_URL for backend automatically)
FHIR_SERVICE_URL=http://localhost:8001/fhir/bundle

# Supabase — backend uses SUPABASE_KEY (service_role) for storage + DB writes.
# Do not use service_role in browsers; web dashboard can use SUPABASE_ANON_KEY with RLS policies.
SUPABASE_URL=
SUPABASE_KEY=
# Alias documented for teams following hackathon brief:
# SUPABASE_SERVICE_KEY=<same as service_role — set as SUPABASE_KEY above>

SUPABASE_ANON_KEY=

# Public URL of FastAPI (for reference / Android physical device testing)
BACKEND_URL=http://localhost:8000
